---
const items = [
  { label: "SDK", desc: "Typed client, React hooks, Vercel AI SDK middleware." },
  { label: "MCP Aggregation", desc: "Register MCP servers once, expose across all harnesses." },
  { label: "Docker Self-Hosting", desc: "First-party compose stack with persistent volumes." },
  { label: "Team Controls", desc: "RBAC, token policy, rate limits for shared deployments." },
  { label: "Document Ingestion", desc: "PDFs, markdown, and URLs into the same retrieval pipeline." },
  { label: "Skills Marketplace", desc: "Install from skills.sh and ClawHub." },
  { label: "Git Sync", desc: "Version identity and memory in your own remote." },
  { label: "Browser Extension", desc: "Chrome and Firefox. Highlight-to-remember." },
  { label: "Dashboard", desc: "Web UI for memory inspection, search, and management." }
];
---

<section id="advanced" class="container" style="border-top: 1px solid var(--color-border)">
  <div class="section-header reveal">
    <div class="crosshair"></div>
    <span class="section-label">ADVANCED</span>
    <span class="section-index">07 / 08</span>
  </div>

  <div class="advanced-grid reveal">
    {items.map((item) => (
      <div class="advanced-item">
        <h4 class="lp-heading">{item.label}</h4>
        <p class="lp-label">{item.desc}</p>
      </div>
    ))}
  </div>
</section>
