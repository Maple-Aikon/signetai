---
const platforms = [
	{
		name: "Claude Code",
		badge: "Connector",
		desc: "Generates and maintains CLAUDE.md from your identity files. Session hooks fire on start, prompt, and end — feeding conversations into the memory pipeline automatically.",
	},
	{
		name: "OpenCode",
		badge: "Connector",
		desc: "Syncs AGENTS.md into your OpenCode configuration. The runtime plugin handles session lifecycle and memory injection without manual setup.",
	},
	{
		name: "OpenClaw",
		badge: "Connector + Adapter",
		desc: "Patches OpenClaw config for harness integration. The runtime adapter calls the Signet daemon for memory search and secret injection during active sessions.",
	},
	{
		name: "Hermes Agent",
		badge: "Memory Plugin",
		desc: "Deploys a Python memory provider plugin into Hermes Agent. Bridges the full Signet lifecycle — hybrid recall, knowledge graph, compaction, and checkpoint extraction — through Hermes's MemoryProvider interface.",
	},
	{
		name: "Gemini CLI",
		badge: "Connector",
		desc: "Installs the Signet MCP server, writes GEMINI.md, and wires skills into Gemini's settings without replacing your existing CLI workflow.",
	},
	{
		name: "More Platforms",
		badge: "Coming Soon",
		desc: "Cursor, Windsurf, and other editors are on the roadmap. The connector architecture is designed for new platforms to be added with minimal effort.",
	},
];
---

<section id="harnesses" class="container" style="border-top: 1px solid var(--color-border)">
  <div class="section-header reveal">
    <div class="crosshair"></div>
    <span class="section-label">Platform Connectors</span>
    <span class="section-index">04 / 06</span>
  </div>

  <div class="arch-platform-grid reveal">
    {platforms.map((platform) => (
      <div class="arch-platform-card">
        <span class="arch-platform-badge">{platform.badge}</span>
        <h3 class="arch-platform-name">{platform.name}</h3>
        <p class="arch-platform-desc">{platform.desc}</p>
      </div>
    ))}
  </div>

  <div class="arch-harness-insight reveal">
    <strong>Write once, appear everywhere.</strong> Connectors are idempotent — safe to run
    as many times as needed. You define your agent's identity, memory, and skills in
    <code>~/.agents/</code>. The daemon handles syncing to every connected platform.
  </div>
</section>
