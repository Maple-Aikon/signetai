---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import StructuredData from "../../components/StructuredData.astro";
import "../../styles/blog.css";

const posts = (await getCollection("blog"))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://signetai.sh";

const featured = posts[0];
const rest = posts.slice(1);

function formatDate(date: Date) {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	});
}
---

<Base title="Blog — SignetAI" description="Updates, ideas, and technical writing from the Signet team.">
  <Nav />

  <div class="blog-shell">
    <main class="blog-main blog-main--index">
      <header class="blog-index-header">
        <h1>Blog</h1>
      </header>

      <StructuredData data={{
        '@context': 'https://schema.org',
        '@type': 'Blog',
        name: 'SignetAI Blog',
        url: `${siteUrl}/blog/`,
        publisher: {
          '@type': 'Organization',
          name: 'SignetAI',
          url: siteUrl,
        },
      }} />

      {/* Featured post */}
      {featured ? (
        <a class="blog-featured" href={`/blog/${featured.id}/`}>
          {featured.data.image ? (
            <img class="blog-featured-image" src={featured.data.image} alt="" width="780" height="400" loading="eager" />
          ) : null}
          <div class="blog-featured-body">
            <h2>{featured.data.title}</h2>
            <p>{featured.data.description}</p>
            <div class="blog-featured-meta">
              <time datetime={featured.data.date.toISOString().slice(0, 10)}>{formatDate(featured.data.date)}</time>
            </div>
          </div>
        </a>
      ) : null}

      {/* Post grid */}
      <div class="blog-grid">
        {rest.map((post) => (
          <a class="blog-grid-card" href={`/blog/${post.id}/`}>
            <div class="blog-grid-card-body">
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </div>
            <div class="blog-grid-card-footer">
              <time datetime={post.data.date.toISOString().slice(0, 10)}>{formatDate(post.data.date)}</time>
            </div>
          </a>
        ))}
      </div>
    </main>
  </div>

  <Footer />
</Base>
