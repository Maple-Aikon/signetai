---
import { getCollection } from "astro:content";
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ShareButtons from "../components/ShareButtons.astro";
import GraphViewer from "../components/GraphViewer";
import "../styles/blog.css";
import "../styles/docs.css";
import "../styles/graph.css";

interface Props {
	title: string;
	description?: string;
	date: Date;
	author: string;
	tags?: string[];
	image?: string;
	headings?: Array<{ depth: number; slug: string; text: string }>;
	previousPost?: {
		title: string;
		url: string;
	};
	nextPost?: {
		title: string;
		url: string;
	};
	pageUrl?: string;
	currentSlug?: string;
	recommendedPosts?: Array<{
		title: string;
		url: string;
		image?: string;
	}>;
}

const {
	title,
	description,
	date,
	author,
	tags = [],
	image,
	headings = [],
	previousPost,
	nextPost,
	pageUrl,
	currentSlug = "",
	recommendedPosts = [],
} = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length > 2;

// Build blog post list for left sidebar
const allPosts = (await getCollection("blog"))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title={`${title} — SignetAI Blog`} description={description} image={image} type="article">
  <Nav />

  <div class="blog-shell">
    <div class="blog-content-grid">
      <!-- Left rail: blog post list -->
      <aside class="blog-nav-rail">
        <div class="blog-nav-rail-sticky">
          <p class="docs-rail-label">
            <a href="/blog" class="blog-nav-back">All Posts</a>
          </p>
          <ul class="blog-nav-list">
            {allPosts.map((post) => (
              <li>
                <a
                  href={`/blog/${post.id}/`}
                  class="blog-nav-link"
                  aria-current={post.id === currentSlug ? "page" : undefined}
                >
                  {post.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- Main content -->
      <main class="blog-main">
        {image ? (
          <img class="blog-hero-image" src={image} alt="" width="1408" height="768" loading="eager" />
        ) : null}

        <header class="blog-article-header">
          <p class="blog-kicker">
            <a href="/blog">&larr; Blog</a>
          </p>
          <h1>{title}</h1>
          <div class="blog-meta">
            <time datetime={date.toISOString().slice(0, 10)}>{formattedDate}</time>
            <span class="blog-meta-separator">/</span>
            <span>{author}</span>
          </div>
          {description ? <p class="blog-description">{description}</p> : null}
          {tags.length > 0 ? (
            <div class="blog-tags">
              {tags.map((tag) => (
                <span class="blog-tag">{tag}</span>
              ))}
            </div>
          ) : null}
          {pageUrl ? <ShareButtons url={pageUrl} title={title} /> : null}
        </header>

        {hasToc ? (
          <nav class="blog-toc-inline" aria-label="Table of contents">
            <p class="blog-toc-label">On this page</p>
            <ul class="blog-toc-list">
              {tocHeadings.filter((h) => h.depth === 2).map((h) => (
                <li><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
            </ul>
          </nav>
        ) : null}

        <article class="prose blog-prose">
          <slot />
        </article>

        {recommendedPosts.length > 0 ? (
          <div class="blog-recommended-section">
            <p class="blog-toc-label">Recommended</p>
            <div class="blog-recommended-grid">
              {recommendedPosts.map((rec) => (
                <a href={rec.url} class="blog-recommended-card">
                  {rec.image ? (
                    <img
                      class="blog-recommended-img"
                      src={rec.image}
                      alt=""
                      width="400"
                      height="200"
                      loading="lazy"
                    />
                  ) : null}
                  <span class="blog-recommended-title">{rec.title}</span>
                </a>
              ))}
            </div>
          </div>
        ) : null}

        {(previousPost || nextPost) ? (
          <nav class="blog-pager" aria-label="Post navigation">
            {previousPost ? (
              <a class="blog-pager-link" href={previousPost.url} rel="prev">
                <span class="blog-pager-label">Previous</span>
                <span class="blog-pager-title">{previousPost.title}</span>
              </a>
            ) : <span class="blog-pager-spacer"></span>}

            {nextPost ? (
              <a class="blog-pager-link" href={nextPost.url} rel="next">
                <span class="blog-pager-label">Next</span>
                <span class="blog-pager-title">{nextPost.title}</span>
              </a>
            ) : <span class="blog-pager-spacer"></span>}
          </nav>
        ) : null}
      </main>

      <!-- Right rail: TOC + graph -->
      {hasToc ? (
        <aside class="blog-toc-rail">
          <div class="blog-toc-rail-sticky">
            <nav aria-label="Table of contents">
              <p class="docs-rail-label">On this page</p>
              <ul class="docs-rail-toc-list">
                {tocHeadings.map((h) => (
                  <li class:list={[{ "docs-rail-toc-sub": h.depth === 3 }]}>
                    <a href={`#${h.slug}`} data-toc-link>{h.text}</a>
                  </li>
                ))}
              </ul>
            </nav>

            {currentSlug ? (
              <GraphViewer client:idle currentSlug={currentSlug} collection="blog" mode="local" />
            ) : null}
          </div>
        </aside>
      ) : null}
    </div>
  </div>

  <Footer />
</Base>

<script>
  function initScrollSpy() {
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
    if (!links.length) return;

    const headingIds = Array.from(links).map((a) => a.getAttribute('href')?.slice(1)).filter(Boolean) as string[];
    const headings = headingIds.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];

    if (!headings.length) return;

    let active: HTMLAnchorElement | null = null;

    function update() {
      const scrollY = window.scrollY + 100;
      let current: string | null = null;

      for (let i = headings.length - 1; i >= 0; i--) {
        if (headings[i].offsetTop <= scrollY) {
          current = headings[i].id;
          break;
        }
      }

      if (!current && headings.length) {
        current = headings[0].id;
      }

      if (active) active.removeAttribute('data-active');
      if (current) {
        const next = document.querySelector<HTMLAnchorElement>(`[data-toc-link][href="#${current}"]`);
        if (next) {
          next.setAttribute('data-active', '');
          active = next;
        }
      }
    }

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => { update(); ticking = false; });
        ticking = true;
      }
    }, { passive: true });

    update();
  }

  initScrollSpy();
  document.addEventListener('astro:after-swap', initScrollSpy);
</script>
