---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/landing/Hero.astro";
import Showcase from "../components/landing/Showcase.astro";
import CoreCapabilities from "../components/landing/CoreCapabilities.astro";
import Benchmark from "../components/landing/Benchmark.astro";
import InstallCta from "../components/landing/InstallCta.astro";
import StructuredData from "../components/StructuredData.astro";
import "../styles/landing.css";

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://signetai.sh";
---

<Base>
  <StructuredData data={{
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'SignetAI',
    url: siteUrl,
    description: "Local-first persistent memory for AI agents. Ambient extraction, knowledge graph, cross-harness runtime.",
  }} />
  <StructuredData data={{
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Signet',
    url: siteUrl,
    description: "Local-first persistent memory for AI agents. Ambient extraction, encrypted secrets, and portable identity across Claude Code, OpenClaw, OpenCode, Codex, and Forge.",
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Linux, macOS',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
  }} />

  <Nav />
  <main class="landing-page">
    <Hero />
    <Showcase />
    <CoreCapabilities />
    <Benchmark />
    <InstallCta />
    <Footer />
  </main>

  <script src="../scripts/theme.ts"></script>
  <script src="../scripts/interactions.ts"></script>
</Base>
