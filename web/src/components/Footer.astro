---

<footer class="container site-footer">
  <div class="footer-left">
    <div class="footer-brand">
      <img src="/Signet-Logo-White.png" alt="" class="footer-logo" width="24" height="24" aria-hidden="true" />
      <span class="footer-brand-text">SIGNET_AI</span>
    </div>
    <div class="footer-tagline">Local-first persistent memory for AI agents.</div>
    <div class="footer-meta">&copy; 2026 SIGNET. ALL RIGHTS RESERVED.</div>
  </div>

  <div class="footer-right">
    <div class="footer-nav">
      <div class="footer-nav-col">
        <span class="footer-nav-label">Product</span>
        <a href="/docs">Docs</a>
        <a href="/how-it-works">How It Works</a>
        <a href="https://github.com/Signet-AI/signetai/tree/main/spec">Spec</a>
      </div>
      <div class="footer-nav-col">
        <span class="footer-nav-label">Resources</span>
        <a href="/blog">Blog</a>
        <a href="https://discord.gg/pHa5scah9C">Discord</a>
        <a href="https://x.com/signetai">X / Twitter</a>
      </div>
    </div>

    <div class="footer-links">
      <a href="https://github.com/Signet-AI/signetai" aria-label="GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
      </a>
      <a href="https://www.npmjs.com/package/signetai" aria-label="npm">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M1.763 0C.786 0 0 .786 0 1.763v20.474C0 23.214.786 24 1.763 24h20.474c.977 0 1.763-.786 1.763-1.763V1.763C24 .786 23.214 0 22.237 0zM5.13 5.323l13.837.019-.009 13.836h-3.464l.01-10.382h-3.456L12.04 19.17H5.113z"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-xl);
    border-top: 1px solid var(--color-border);
    gap: 40px;
    flex-wrap: wrap;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-logo {
    filter: drop-shadow(0 0 8px var(--color-highlight-muted));
  }

  .footer-brand-text {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-text-bright);
  }

  .footer-tagline {
    font-size: 13px;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .footer-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    gap: 32px;
    align-items: flex-end;
  }

  .footer-nav {
    display: flex;
    gap: 48px;
  }

  .footer-nav-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-nav-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text-bright);
    font-weight: 600;
    margin-bottom: 4px;
  }

  .footer-nav-col a {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.2s var(--ease);
  }

  .footer-nav-col a:hover {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  .footer-links {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .footer-links a {
    color: var(--color-text-muted);
    transition: all 0.2s var(--ease);
  }

  .footer-links a:hover {
    color: var(--color-text-bright);
    transform: translateY(-2px);
  }

  @media (max-width: 720px) {
    .site-footer {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    
    .footer-left {
      align-items: center;
    }

    .footer-right {
      align-items: center;
    }

    .footer-nav {
      gap: 32px;
      text-align: left;
    }
    
    .footer-nav-col a:hover {
      transform: none;
    }
  }
</style>

