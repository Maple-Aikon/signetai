---
const steps = [
  {
    num: "01",
    label: "Session ends",
    desc: "Your coding agent finishes work. The full transcript is captured."
  },
  {
    num: "02",
    label: "Signet distills",
    desc: "Entities, decisions, and context are extracted into structured memory and knowledge graph."
  },
  {
    num: "03",
    label: "Next session starts",
    desc: "Relevant context is injected before the first prompt. The agent picks up where it left off."
  }
];
---

<section id="workflow" class="container" style="border-top: 1px solid var(--color-border)">
  <div class="section-header reveal">
    <div class="crosshair"></div>
    <span class="section-label">HOW IT WORKS</span>
    <span class="section-index">02 / 08</span>
  </div>

  <div class="workflow-strip reveal">
    {steps.map((step, i) => (
      <div class:list={["workflow-step", { "workflow-step--final": i === steps.length - 1 }]}>
        <span class="workflow-num">{step.num}</span>
        <h3 class="workflow-label">{step.label}</h3>
        <p class="workflow-desc">{step.desc}</p>
      </div>
    ))}
  </div>
</section>
