---
const steps = [
  "transcript preserved and distilled into structured memory",
  "entities, constraints, and relations linked into navigable graph",
  "traversal + flat search build bounded candidate pool",
  "predictive scorer reranks against interaction patterns",
  "fail-open guards keep baseline if model is cold",
  "post-fusion dampening separates signal from noise",
  "right context injected before next prompt starts"
];
---

<section id="pipeline-flow" class="container" style="border-top: 1px solid var(--color-border)">
  <div class="section-header reveal">
    <div class="crosshair"></div>
    <span class="section-label">PIPELINE</span>
    <span class="section-index">05 / 08</span>
  </div>

  <div class="pipeline-flow reveal">
    {steps.map((step, i) => (
      <div class="pipeline-step">
        <div class="lp-node"></div>
        <p class="lp-label">{step}</p>
      </div>
    ))}
  </div>

  <p class="pipeline-closing reveal">No manual memory tool calls after setup.</p>
</section>
